# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.css text
*.html text
*.js text
*.jsx text
*.json text
*.md text
*.scss text
*.ts text
*.tsx text
*.xml text
*.yml text
*.yaml text

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
